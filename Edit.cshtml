@model VisitorMVC.Models.DTOs.VisitorRequestDto

@{
    ViewData["Title"] = "Edit Request";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <h3>
                Create Visitor Request
            </h3>

        </div>

        <div class="card-body">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">

                    @ViewBag.Error

                </div>
            }

            <form asp-action="Edit"
                  method="post">

                <input asp-for="RequestId"
                       type="hidden" />
                @Html.AntiForgeryToken()

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Visitor Name
                        </label>

                        <input asp-for="VisitorName"
                               class="form-control" />

                        <span asp-validation-for="VisitorName"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Mobile Number
                        </label>

                        <input asp-for="MobileNumber" id="mobile" maxlength="10"
                               class="form-control" />

                        <span asp-validation-for="MobileNumber"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Company Name
                        </label>

                        <input asp-for="CompanyName"
                               class="form-control" />

                        <span asp-validation-for="CompanyName"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Person To Meet
                        </label>

                        <input asp-for="PersonToMeet"
                               class="form-control" />

                        <span asp-validation-for="PersonToMeet"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Purpose Of Visit
                        </label>

                        <input asp-for="PurposeOfVisit"
                               class="form-control" />

                        <span asp-validation-for="PurposeOfVisit"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Visit Date
                        </label>

                        <input asp-for="VisitDate"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="VisitDate" id="Visit_Date"
                              class="text-danger">
                        </span>

                    </div>

                </div>

                <button type="submit"
                        class="btn btn-success">

                    Update Request

                </button>

                <a asp-action="Index"
                       class="btn btn-secondary">

                    Back

                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
<script src="~/js/JqGrid/js/jquery.min.js"></script>

<script>
    const today = new Date().toISOString().split('T')[0];
    $("#Visit_Date").attr("min", today);
 
    $("#mobile").on("input", function() {
        this.value = this.value.replace(/\D/g, "");
    });
</script>