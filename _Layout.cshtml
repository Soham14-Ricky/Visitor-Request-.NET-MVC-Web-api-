<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"]
    </title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/free-jqgrid@4.15.5/css/ui.jqgrid.min.css" />

    <link rel="stylesheet"
          href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" asp-append-version="true" />

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

        <div class="container-fluid">

            <a class="navbar-brand"
                   href="#">

                Visitor System

            </a>

            <div class="collapse navbar-collapse">

                <ul class="navbar-nav me-auto">

                    @if (Context.Session.GetString("UserRole")
                    == "Employee")
                    {
                        <li class="nav-item">

                            <a class="nav-link"
                                   asp-controller="VisitorRequest"
                                   asp-action="Index">

                                My Requests

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                                   asp-controller="VisitorRequest"
                                   asp-action="Create">

                                Create Request

                            </a>

                        </li>
                    }

                    @if (Context.Session.GetString("UserRole")
                    == "Admin")
                    {
                        <li class="nav-item">

                            <a class="nav-link"
                                   asp-controller="Admin"
                                   asp-action="Index">

                                Admin Dashboard

                            </a>

                        </li>
                    }

                </ul>

                <span class="text-white me-3">

                    Welcome
                    @Context.Session.GetString("Username")

                </span>

                <a asp-controller="Account"
                       asp-action="Logout"
                       class="btn btn-danger">

                    Logout

                </a>

            </div>

        </div>

    </nav>

    <div class="container mt-3">

        @RenderBody()

    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>

</html>