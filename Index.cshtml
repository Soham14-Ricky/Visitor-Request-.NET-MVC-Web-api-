@model IEnumerable<VisitorMVC.Models.DTOs.VisitorRequestDto>

@{
    ViewData["Title"] = "My Requests";
}

<div class="container mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">

            @TempData["Success"]

        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">

            @TempData["Error"]

        </div>
    }

    <div class="d-flex justify-content-between mb-3">

        <h3>
            My Visitor Requests
        </h3>

        <a asp-action="Create"
               class="btn btn-primary">

            Create Request

        </a>

    </div>

    <table id="requestGrid"></table>

    <div id="requestPager"></div>

</div>

<!-- ================= SCRIPTS ================= -->
<script src="~/js/JqGrid/js/jquery.min.js"></script>
<script src="~/js/JqGrid/js/jquery-ui.min.js"></script>
<script src="~/js/JqGrid/js/grid.locale-en.js"></script>
<script src="~/js/JqGrid/js/jquery.jqGrid.min.js"></script>
<script src="~/js/JqGrid/js/jszip.min.js"></script>

<script>
    var requestData = @Html.Raw( Newtonsoft.Json.JsonConvert.SerializeObject(Model));
</script>
<script src="~/js/visitorRequestPage.js"></script>
